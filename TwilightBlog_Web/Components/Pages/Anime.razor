@page "/anime"
@inject IAnixartService AnixartService
@inject IStringLocalizer<UI> L

<PageTitle>@L["Nav.Anime"]</PageTitle>

<div class="anime-page">
	<h1 class="page-title">@L["Page.Anime.Title"]</h1>

	@if (_loading)
	{
		<p class="loading">@L["Page.Home.Loading"]</p>
	}
	else if (_error is not null)
	{
		<p class="error">@_error</p>
	}
	else if (_titles.Count == 0)
	{
		<p class="empty">@L["Page.Anime.Empty"]</p>
	}
	else
	{
		<p class="anime-page__count">@_titles.Count @L["Page.Anime.Count"]</p>

		<div class="anime-grid">
			@foreach (var title in _titles)
			{
				<div class="anime-card">
					<div class="anime-card__poster-wrap">
						@if (!string.IsNullOrEmpty(title.Image))
						{
							<img class="anime-card__poster"
								 src="@title.Image"
								 alt="@title.TitleRu"
								 loading="lazy" />
						}
						else
						{
							<div class="anime-card__poster-placeholder">?</div>
						}
						@if (title.Category is not null)
						{
							<span class="anime-card__category">@title.Category.Name</span>
						}
					</div>
					<div class="anime-card__info">
						@if (L["Lang"].Value == "en")
						{
							<h3 class="anime-card__title">@title.TitleOriginal</h3>
							@if (!string.IsNullOrEmpty(title.TitleRu))
							{
								<p class="anime-card__original">@title.TitleRu</p>
							}
						}
						else
						{
							<h3 class="anime-card__title">@title.TitleRu</h3>
							@if (!string.IsNullOrEmpty(title.TitleOriginal))
							{
								<p class="anime-card__original">@title.TitleOriginal</p>
							}
						}
						<div class="anime-card__meta">
							@if (title.Year.HasValue)
							{
								<span>@title.Year</span>
							}
							@if (title.Grade.HasValue)
							{
								<span class="anime-card__rating">★ @title.Grade.Value.ToString("0.0")</span>
							}
							@if (title.EpisodesReleased.HasValue)
							{
								<span>@title.EpisodesReleased @L["Page.Anime.Episodes"]</span>
							}
						</div>
						@if (title.Genres.Count > 0)
						{
							<div class="anime-card__genres">
								@foreach (var genre in title.Genres.Take(3))
								{
									<span class="tag tag--small">@genre</span>
								}
							</div>
						}
						@if (!string.IsNullOrEmpty(title.UserComment))
						{
							<div class="anime-comment-wrap">
								<button class="comment-btn"
										@onclick="() => ToggleComment(title.Id)">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="var(--md-secondary)">
										<path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z" />
									</svg>
								</button>
								@if (_openComments.Contains(title.Id))
								{
									<div class="comment-bubble">
										<TypewriterText Text="@title.UserComment" />
									</div>
								}
							</div>
						}
					</div>
				</div>
			}
		</div>
	}
</div>

@code {
	private List<AnimeTitle> _titles = new();
	private bool _loading = true;
	private string? _error;
	private HashSet<int> _openComments = new();

	protected override async Task OnInitializedAsync()
	{
		try
		{
			_titles = await AnixartService.GetCompletedAsync();
		}
		catch (Exception ex)
		{
			_error = $"{L["Page.Anime.Error"]} {ex.Message}";
		}
		finally
		{
			_loading = false;
		}
	}

	private void ToggleComment(int id)
	{
		if (_openComments.Contains(id))
			_openComments.Remove(id);
		else
			_openComments.Add(id);
	}
}