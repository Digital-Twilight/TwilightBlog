@page "/games"
@inject ISteamService SteamService
@inject IStringLocalizer<UI> L

<PageTitle>@L["Nav.Games"]</PageTitle>

<div class="games-page">
    <h1 class="page-title">@L["Page.Games.Title"]</h1>

    @if (_loading)
    {
        <p class="loading">@L["Page.Home.Loading"]</p>
    }
    else if (_error is not null)
    {
        <p class="error">@_error</p>
    }
    else if (_games.Count == 0)
    {
        <p class="empty">@L["Page.Games.Empty"]</p>
    }
    else
    {
        <p class="games-page__count">@_games.Count @L["Page.Games.Games"] · @TotalHours @L["Page.Games.Hours"]</p>

        <div class="games-grid">
            @foreach (var game in _games)
            {
                <div class="game-card">
                    <div class="game-card__header-wrap">
                        @if (!string.IsNullOrEmpty(game.HeaderUrl))
                        {
                            <img class="game-card__header"
                                 src="@game.HeaderUrl"
                                 alt="@game.Name"
                                 loading="lazy"
                                 onerror="this.style.display='none'" />
                        }
                    </div>
                    <div class="game-card__info">
                        <div class="game-card__top">
                            @if (!string.IsNullOrEmpty(game.IconUrl))
                            {
                                <img class="game-card__icon"
                                     src="@game.IconUrl"
                                     alt=""
                                     loading="lazy" />
                            }
                            <h3 class="game-card__name">@game.Name</h3>
                        </div>
                        <div class="game-card__meta">
                            <span class="game-card__playtime">🕐 @FormatPlaytime(game.PlaytimeMinutes)</span>
                            <a href="https://store.steampowered.com/app/@game.AppId"
                               target="_blank"
                               class="game-card__store-link">
                                Steam →
                            </a>
                        </div>
                        @if (!string.IsNullOrEmpty(game.UserComment))
                        {
                            <blockquote class="game-card__comment">@game.UserComment</blockquote>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<SteamGame> _games = new();
    private bool _loading = true;
    private string? _error;

    private string TotalHours =>
        (_games.Sum(g => g.PlaytimeMinutes) / 60).ToString("N0");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _games = await SteamService.GetOwnedGamesAsync();
        }
        catch (Exception ex)
        {
            _error = $"{@L["Page.Games.Error"]} {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private string FormatPlaytime(int minutes)
    {
        var hours = minutes / 60;
        var mins = minutes % 60;
        var h = L["Page.Games.Playtime.Hours"].Value;
        var m = L["Page.Games.Playtime.Minutes"].Value;

        if (minutes < 60)
            return mins + " " + m;

        return hours + " " + h + " " + mins + " " + m;
    }
}