@page "/games"
@inject ISteamService SteamService

<PageTitle>Игры</PageTitle>

<div class="games-page">
    <h1 class="page-title">Игры</h1>

    @if (_loading)
    {
        <p class="loading">Загрузка...</p>
    }
    else if (_error is not null)
    {
        <p class="error">@_error</p>
    }
    else if (_games.Count == 0)
    {
        <p class="empty">Игр не найдено.</p>
    }
    else
    {
        <p class="games-page__count">@_games.Count игр · @TotalHours ч наиграно</p>

        <div class="games-grid">
            @foreach (var game in _games)
            {
                <div class="game-card">
                    <div class="game-card__header-wrap">
                        @if (!string.IsNullOrEmpty(game.HeaderUrl))
                        {
                            <img class="game-card__header"
                                 src="@game.HeaderUrl"
                                 alt="@game.Name"
                                 loading="lazy"
                                 onerror="this.style.display='none'" />
                        }
                    </div>
                    <div class="game-card__info">
                        <div class="game-card__top">
                            @if (!string.IsNullOrEmpty(game.IconUrl))
                            {
                                <img class="game-card__icon"
                                     src="@game.IconUrl"
                                     alt=""
                                     loading="lazy" />
                            }
                            <h3 class="game-card__name">@game.Name</h3>
                        </div>
                        <div class="game-card__meta">
                            <span class="game-card__playtime">🕐 @game.PlaytimeFormatted</span>
                            <a href="https://store.steampowered.com/app/@game.AppId"
                               target="_blank"
                               class="game-card__store-link">
                                Steam →
                            </a>
                        </div>
                        @if (!string.IsNullOrEmpty(game.UserComment))
                        {
                            <blockquote class="game-card__comment">@game.UserComment</blockquote>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<SteamGame> _games = new();
    private bool _loading = true;
    private string? _error;

    private string TotalHours =>
        (_games.Sum(g => g.PlaytimeMinutes) / 60).ToString("N0");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _games = await SteamService.GetOwnedGamesAsync();
        }
        catch (Exception ex)
        {
            _error = $"Не удалось загрузить список игр: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}